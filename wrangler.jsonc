{
  "name": "yun-perfume",
  "compatibility_date": "2024-11-18",
  "compatibility_flags": ["nodejs_compat"],
  "pages_build_output_dir": ".next",
  "kv_namespaces": [
    {
      "binding": "SESSIONS",
      "id": "change-me-later"
    }
  ],
  "r2_buckets": [
    {
      "binding": "IMAGES",
      "bucket_name": "yun-perfume-images"
    }
  ]
}
